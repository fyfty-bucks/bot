#!/usr/bin/env python3
"""Agent CLI entry point — auto-selects venv if available."""
import os
import sys
from pathlib import Path

_VENV = Path(__file__).resolve().parent / ".venv" / "bin" / "python3"
if _VENV.exists() and Path(sys.executable).resolve() != _VENV.resolve():
    os.execv(str(_VENV), [str(_VENV)] + sys.argv)

from src.cli import main
sys.exit(main() or 0)
